# ============================================
# Inspo-Verse 生产环境变量模板
# ============================================
# 使用方式：
#   1. 复制本文件到服务器 /www/wwwroot/Inspo-Verse/.env
#   2. 填写所有必需的值
#   3. chmod 600 .env
# ============================================

# ---------- 云数据库 (腾讯云 MySQL) ----------
DB_HOST=你的数据库地址.sql.tencentcdb.com
DB_PORT=3306
DB_NAME=inspo_verse
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ---------- Redis（本项目独立 Redis 实例）----------
REDIS_PASSWORD=your_redis_password

# ---------- JWT 认证 ----------
# 至少 64 字符的随机字符串，生成方法: openssl rand -base64 64
JWT_SECRET=替换为你生成的JWT密钥

# ---------- AI 服务内部通信签名 ----------
# 用于 Java 后端 ↔ Python AI 服务之间的内部鉴权
# 生成方法: openssl rand -hex 32
AI_INTERNAL_SIGN_KEY=替换为随机内部签名密钥

# ---------- 通义千问 AI (DashScope) ----------
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- 腾讯云 COS 对象存储 ----------
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-beijing
COS_BUCKET=your-bucket-name

# ---------- 百度 AI ----------
BAIDU_AI_APP_ID=your_app_id
BAIDU_AI_API_KEY=your_api_key
BAIDU_AI_SECRET_KEY=your_secret_key

# ---------- 邮件服务配置 ----------
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your_email@163.com
MAIL_PASSWORD=your_email_authorization_code
MAIL_NICKNAME=Inspo-Verse灵感岛

# ---------- CORS 前端访问地址 ----------
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ---------- 第三方支付 (Epay) ----------
EPAY_MERCHANT_ID=your_merchant_id
EPAY_MERCHANT_KEY=your_merchant_key
EPAY_API_URL=https://your-epay-gateway/
EPAY_SUBMIT_URL=https://your-epay-gateway/submit.php
EPAY_MAPI_URL=https://your-epay-gateway/mapi.php
# 后端公网地址，Epay 异步通知回调用（必须外网可达）
PAYMENT_NOTIFY_BASE_URL=https://your-domain.com:8081

# ---------- 阿里云容器镜像 ACR (由 CI/CD 自动更新) ----------
TCR_NAMESPACE=your_acr_namespace
